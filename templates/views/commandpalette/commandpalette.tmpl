<window title="Command Palette" width="50" height="15" center="true" padding="1">
  <vbox gap="1">
    <input id="search" placeholder="Search commands..." />
    <list id="commands" items="${commands}" />
    <spacer height="1" />
    <text value="↑↓ navigate  Enter select  Esc close" color="#888888" />
  </vbox>
</window>
