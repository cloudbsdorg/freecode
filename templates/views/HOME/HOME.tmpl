<window id="home" title="Freecode" center="true">
  <vbox padding="2" gap="1">
    <spacer height="${bannerSpacer}" />
    <text id="banner" value="${banner}" bold="true" />
    <spacer height="1" />
    <hbox>
      <spacer width="${inputPadding}" />
      <input id="input" placeholder="Ask anything..." width="${inputWidth}" />
    </hbox>
    <spacer flex="1" />
    <text id="hints" value="Ctrl+P: Command Palette | Ctrl+B: Toggle Sidebar | Ctrl+H: Home | Ctrl+Q: Quit" color="#606060" />
  </vbox>
</window>
