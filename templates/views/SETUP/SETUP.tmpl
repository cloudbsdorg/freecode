<window id="setup" title="Freecode Setup" center="true" padding="2">
  <vbox gap="1">
    <text id="title" value="Welcome to Freecode Setup" bold="true" />
    <spacer height="1" />
    <text id="provider-label" value="Select a provider:" />
    <text id="providers" value="${providers}" />
    <spacer flex="1" />
    <hbox gap="2">
      <spacer flex="1" />
      <button id="cancel" label="Cancel" />
      <button id="next" label="Next" primary="true" />
    </hbox>
  </vbox>
</window>
